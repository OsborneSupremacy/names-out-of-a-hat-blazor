{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "properties": {
        "subject": {
            "type": "string",
            "minLength": 1,
            "maxLength": 500,
            "description": "The subject line for the invitation preview"
        },
        "htmlBody": {
            "type": "string",
            "minLength": 1,
            "maxLength": 2000,
            "description": "The HTML body for the invitation preview"
        }
    },
    "required": [
        "subject",
        "htmlBody"
    ],
    "additionalProperties": false
}
